# =============================================================================
# SYNTHGUARD ORCHESTRATOR - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ORCHESTRATOR SETTINGS
# -----------------------------------------------------------------------------
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=9000
ORCHESTRATOR_DEBUG=true
ORCHESTRATOR_RELOAD=true

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Enable/disable layers (for testing)
LAYER1_ENABLED=true
LAYER2_3_ENABLED=true
LAYER4_ENABLED=false
LAYER5_ENABLED=true

# -----------------------------------------------------------------------------
# LAYER ENDPOINTS
# -----------------------------------------------------------------------------
# Layer 1: Document Forensics (Flask server)
LAYER1_URL=http://localhost:5000
LAYER1_ENDPOINT=/api/analyze

# Layer 2&3: OSINT + Graph Analysis (FastAPI server)
LAYER2_3_URL=http://localhost:8000
LAYER2_3_ENDPOINT=/api/analyze

# Layer 4: Behavioral Patterns (TBD - update when ready)
LAYER4_URL=http://localhost:6000
LAYER4_ENDPOINT=/api/analyze-behavior

# Layer 5: Blockchain Verification (Direct Python import)
# No URL needed - uses direct module import

# -----------------------------------------------------------------------------
# BLOCKCHAIN CONFIGURATION (LAYER 5)
# -----------------------------------------------------------------------------
# Polygon Amoy Testnet RPC
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Your wallet private key (NEVER commit to Git!)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed contract address (from layer5/deployment-info.json)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Your wallet address
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# -----------------------------------------------------------------------------
# SCORING WEIGHTS (Sum must equal 1.0)
# -----------------------------------------------------------------------------
WEIGHT_LAYER1=0.25
WEIGHT_LAYER2_3=0.50
WEIGHT_LAYER4=0.15
WEIGHT_LAYER5=0.10

# -----------------------------------------------------------------------------
# VERDICT THRESHOLDS
# -----------------------------------------------------------------------------
THRESHOLD_VERIFIED=90
THRESHOLD_SUSPICIOUS=50

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=orchestrator.log
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# CORS SETTINGS (for frontend)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# RATE LIMITING (Optional - for production)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# CACHING (Optional - for performance)
# -----------------------------------------------------------------------------
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# MONITORING (Optional - for production)
# -----------------------------------------------------------------------------
METRICS_ENABLED=false
METRICS_PORT=9091